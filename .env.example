# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tablewise
DATABASE_USER=tablewise_user
DATABASE_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_here
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@tablewise.com.tr
SENDGRID_FROM_NAME=Tablewise

# Netgsm (SMS)
NETGSM_USERNAME=your_netgsm_username_here
NETGSM_PASSWORD=your_netgsm_password_here
NETGSM_SENDER=TABLEWISE

# İyzico
IYZICO_API_KEY=your_iyzico_api_key_here
IYZICO_SECRET_KEY=your_iyzico_secret_key_here
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Cloudflare R2 (S3-Compatible)
R2_ACCESS_KEY=your_r2_access_key_here
R2_SECRET_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=tablewise-files
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.tablewise.com.tr

# Serilog
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=your_seq_api_key_here

# Sentry
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://tablewise.com.tr,https://app.tablewise.com.tr

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PERIOD_SECONDS=60
RATE_LIMIT_LIMIT=100

# SignalR
SIGNALR_ENABLED=false

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
