    "ConnectRetry": 3,
    "ConnectTimeoutMs": 5000
  },
  "Cors": {
    "AllowedOrigins": [
      "https://tablewise.com.tr",
      "https://app.tablewise.com.tr"
    ]
  },
  "Sentry": {
    "Dsn": ""
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "R2": {
    "AccountId": "",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "tablewise-files",
    "PublicUrlBase": "https://cdn.tablewise.com.tr",
    "LogoMaxUploadBytes": 2097152,
