{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=tablewise;Username=tablewise_user;Password=dev_password;Include Error Detail=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EnableDetailedErrors": false,
  "Jwt": {
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MIN_32_CHARS_REPLACE_IN_PRODUCTION",
